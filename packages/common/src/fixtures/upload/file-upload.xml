<?xml version="1.0"?>
<h:html xmlns="http://www.w3.org/2002/xforms" xmlns:h="http://www.w3.org/1999/xhtml"
        xmlns:ev="http://www.w3.org/2001/xml-events" xmlns:xsd="http://www.w3.org/2001/XMLSchema"
        xmlns:jr="http://openrosa.org/javarosa" xmlns:orx="http://openrosa.org/xforms"
        xmlns:odk="http://www.opendatakit.org/xforms">
  <h:head>
    <h:title>File Upload</h:title>
    <model odk:xforms-version="1.0.0">
      <instance>
        <data id="file_upload" version="2025020401">
          <audio/>
          <video/>
          <doc/>
          <meta>
            <instanceID/>
          </meta>
        </data>
      </instance>

      <bind nodeset="/data/audio" type="binary" required="true()" />
      <bind nodeset="/data/video" type="binary" required="true()" />
      <bind nodeset="/data/doc" type="binary" required="true()" />
    </model>
  </h:head>
  <h:body>
    <upload mediatype="audio/*" ref="/data/audio">
      <label>Upload audio</label>
    </upload>
    <upload mediatype="video/*" ref="/data/video">
      <label>Upload video</label>
    </upload>
    <upload accept=".pdf" ref="/data/doc">
      <label>Upload PDF</label>
    </upload>
  </h:body>
</h:html>
